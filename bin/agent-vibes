#!/usr/bin/env node
/**
 * agent-vibes CLI — Unified Agent Gateway
 *
 * Usage:
 *   agent-vibes                          Start the gateway server
 *   agent-vibes cert                     Generate SSL certificates
 *   agent-vibes sync --ide|--tools       Sync Antigravity credentials
 *   agent-vibes sync --claude            Sync Claude Code third-party credentials
 *   agent-vibes sync --codex             Sync Codex credentials
 *   agent-vibes forward hosts|on|off|status
 *   agent-vibes sync --deploy [--run]    Deploy credentials to GitHub Secrets
 *   agent-vibes --version                Show version
 *   agent-vibes --help                   Show help
 */

const path = require("path")
const fs = require("fs")
const { spawnSync } = require("child_process")

const ROOT = path.resolve(__dirname, "..")
const args = process.argv.slice(2)
const command = args[0]

// --version
if (args.includes("--version") || args.includes("-v")) {
  const pkg = JSON.parse(
    fs.readFileSync(
      path.join(ROOT, "apps", "protocol-bridge", "package.json"),
      "utf-8"
    )
  )
  console.log(`agent-vibes v${pkg.version}`)
  process.exit(0)
}

// --help
if (
  command === "help" ||
  command === "--help" ||
  command === "-h" ||
  (!command && (args.includes("--help") || args.includes("-h")))
) {
  console.log(`
agent-vibes — Unified Agent Gateway

Enables Claude Code CLI and Cursor IDE to use Antigravity AI backends
through protocol translation.

Usage:
  agent-vibes                         Start the gateway server
  agent-vibes --version               Show version
  agent-vibes --help                  Show help

Configuration:
  Antigravity:
    agent-vibes sync --ide            Sync credentials from Antigravity IDE
    agent-vibes sync --tools          Sync credentials from Antigravity Manager
  Claude:
    agent-vibes sync --claude         Sync credentials from Claude Code settings
  Codex:
    agent-vibes sync --codex          Sync credentials from Codex CLI auth.json
  Cursor:
    agent-vibes cert                  Generate SSL certificates (requires mkcert)
    agent-vibes forward hosts         Print /etc/hosts entries
    agent-vibes forward on            Enable port forwarding (requires sudo)
    agent-vibes forward off           Disable port forwarding (requires sudo)
    agent-vibes forward status        Show forwarding status

Deployment:
  agent-vibes sync --deploy           Deploy credentials to GitHub Secrets
  agent-vibes sync --deploy --run     Deploy + trigger CI/CD workflow

Advanced:
  agent-vibes patch                   Patch Cursor binary for proxy
  agent-vibes patch --restore         Restore original Cursor binary
  agent-vibes patch --status          Check Cursor patch status
  agent-vibes capture start           Start traffic capture (Clash + mitmdump)
  agent-vibes capture stop            Stop traffic capture
  agent-vibes capture status          Show capture status
  agent-vibes issues                  Collect diagnostics for bug reports

Documentation: https://github.com/funny-vibes/agent-vibes
`)
  process.exit(0)
}

function run(commandName, commandArgs, opts = {}) {
  const result = spawnSync(commandName, commandArgs, {
    cwd: ROOT,
    stdio: "inherit",
    ...opts,
  })
  if (result.error) {
    console.error(result.error.message)
    process.exit(1)
  }
  process.exit(result.status ?? 1)
}

function nodeScript(scriptPath, scriptArgs = [], opts = {}) {
  run(process.execPath, [path.join(ROOT, scriptPath), ...scriptArgs], opts)
}

function tsxScript(scriptPath, scriptArgs = [], opts = {}) {
  run(
    process.execPath,
    ["--import", "tsx", path.join(ROOT, scriptPath), ...scriptArgs],
    opts
  )
}

if (command === "sync") {
  if (args.includes("--deploy")) {
    nodeScript("scripts/accounts/sync-deploy.js", args.slice(1))
  } else if (args.includes("--claude")) {
    nodeScript("scripts/accounts/sync-claude-account.js")
  } else if (args.includes("--codex")) {
    nodeScript("scripts/accounts/sync-codex-account.js")
  } else {
    nodeScript("scripts/accounts/sync-antigravity-accounts.js", args.slice(1))
  }
}

if (command === "cert") {
  // Verify mkcert is available
  const mkcertCheck = spawnSync(
    process.platform === "win32" ? "where" : "which",
    ["mkcert"],
    { encoding: "utf-8", stdio: "pipe" }
  )
  if (mkcertCheck.status !== 0) {
    console.error("Error: mkcert is not installed or not in PATH.\n")
    if (process.platform === "darwin") {
      console.error("  Install with: brew install mkcert && mkcert -install")
    } else if (process.platform === "win32") {
      console.error("  Install with: choco install mkcert  (or scoop install mkcert)")
      console.error("  Then run: mkcert -install")
    } else {
      console.error("  Install with: sudo apt install mkcert  (or see https://github.com/FiloSottile/mkcert)")
      console.error("  Then run: mkcert -install")
    }
    process.exit(1)
  }

  const certDir = path.join(ROOT, "apps", "protocol-bridge", "certs")
  if (!fs.existsSync(certDir)) {
    fs.mkdirSync(certDir, { recursive: true })
  }
  run(
    "mkcert",
    [
      "-cert-file",
      "localhost.crt",
      "-key-file",
      "localhost.key",
      "localhost",
      "*.api5.cursor.sh",
      "*.cursor.sh",
      "api2.cursor.sh",
      "api2geo.cursor.sh",
      "api2direct.cursor.sh",
      "agent.api2.cursor.sh",
      "agentn.api2.cursor.sh",
      "agent.api2geo.cursor.sh",
      "agentn.api2geo.cursor.sh",
      "agent.api2direct.cursor.sh",
      "agentn.api2direct.cursor.sh",
      "agent.api5.cursor.sh",
      "agentn.api5.cursor.sh",
      "agent.api5geo.cursor.sh",
      "agent.api5lat.cursor.sh",
      "agentn.api5geo.cursor.sh",
      "agentn.api5lat.cursor.sh",
      "agent-gcpp-uswest.api5.cursor.sh",
      "agent-gcpp-eucentral.api5.cursor.sh",
      "agent-gcpp-apsoutheast.api5.cursor.sh",
      "agentn-gcpp-uswest.api5.cursor.sh",
      "agentn-gcpp-eucentral.api5.cursor.sh",
      "agentn-gcpp-apsoutheast.api5.cursor.sh",
      "agent.us.api5.cursor.sh",
      "agent.eu.api5.cursor.sh",
      "agent.ap.api5.cursor.sh",
      "agentn.us.api5.cursor.sh",
      "agentn.eu.api5.cursor.sh",
      "agentn.ap.api5.cursor.sh",
      "a.cursor.sh",
      "127.0.0.1",
      "127.0.0.2",
      "127.0.0.3",
      "::1",
    ],
    { cwd: certDir }
  )
}

if (command === "patch") {
  tsxScript("scripts/cursor/patch_transport.ts", args.slice(1), {
    env: {
      ...process.env,
      NO_PROXY: "127.0.0.1,localhost,127.0.0.2,*.cursor.sh,*.azureedge.net",
    },
  })
}

if (command === "forward") {
  const subCmd = args[1] || "status"
  if (subCmd === "on" || subCmd === "off") {
    if (process.platform === "win32") {
      // Windows: node script checks for admin internally
      nodeScript("scripts/proxy/setup-forwarding.js", [subCmd])
    } else {
      run("sudo", [process.execPath, path.join(ROOT, "scripts/proxy/setup-forwarding.js"), subCmd])
    }
  } else {
    nodeScript("scripts/proxy/setup-forwarding.js", [subCmd])
  }
}

if (command === "issues") {
  nodeScript("scripts/diagnostics/collect-issue-logs.js", args.slice(1))
}

if (command === "capture") {
  const subCmd = args[1] || "status"
  if (process.platform === "win32") {
    // Windows: no sudo, scripts check elevation internally
    nodeScript("scripts/capture/capture.js", [subCmd])
  } else {
    run("sudo", [process.execPath, path.join(ROOT, "scripts/capture/capture.js"), subCmd])
  }
}

// Default: start server
const mainPath = path.join(ROOT, "apps", "protocol-bridge", "dist", "main.js")

if (!fs.existsSync(mainPath)) {
  console.error(
    "Error: Server not built. Run 'npm run build' in apps/protocol-bridge first."
  )
  process.exit(1)
}

require(mainPath)
