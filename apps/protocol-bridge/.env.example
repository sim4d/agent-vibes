# Agent Vibes — environment configuration
# Copy to .env.local to customize (optional)
#
# Zero-config for local dev. Configure for server deployment.

# ── Server ──────────────────────────────────────────────────────────────
PORT=8000
# PROXY_API_KEY=your-secret-key

# ── Antigravity Backend ─────────────────────────────────────────────────
# Path to Antigravity OAuth credentials (synced via `agent-vibes sync`)
ANTIGRAVITY_STORAGE=~/.protocol-bridge
# Optional: path to Antigravity.app bundle. If unset, common macOS locations are probed.
# ANTIGRAVITY_APP_PATH=/Applications/Antigravity.app
# Optional advanced override: set both if you need a custom runtime layout.
# ANTIGRAVITY_NODE_BINARY=/Applications/Antigravity.app/Contents/Frameworks/Antigravity Helper (Plugin).app/Contents/MacOS/Antigravity Helper (Plugin)
# ANTIGRAVITY_NODE_MODULES=/Applications/Antigravity.app/Contents/Resources/app/node_modules

# ── Codex Backend (GPT / O-series Models) ───────────────────────────────
# Set CODEX_API_KEY or CODEX_ACCESS_TOKEN to enable GPT/O-series models.
# Without credentials, GPT/O-series requests are rerouted to default Gemini.
#
# Option A: OpenAI API Key (recommended)
# CODEX_API_KEY=sk-xxx
#
# Option B: OAuth2 Access Token (from codex CLI login)
# CODEX_ACCESS_TOKEN=xxx                        # OAuth2 access token
# CODEX_REFRESH_TOKEN=xxx                       # Enables auto-refresh when token expires
# CODEX_ACCOUNT_ID=xxx                          # OpenAI account ID (from JWT claims)
#
# Codex upstream endpoint (default: chatgpt.com Codex API)
# CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
#
# Optional HTTP/HTTPS/SOCKS5 proxy for Codex requests
# CODEX_PROXY_URL=socks5://127.0.0.1:1080
#
# WebSocket transport: lower latency, session reuse, auto-fallback to HTTP
# CODEX_USE_WEBSOCKET=false

# ── Third-party OpenAI-compatible Backend ────────────────────────────────
# Set OPENAI_COMPAT_BASE_URL + OPENAI_COMPAT_API_KEY to route GPT/O-series
# to a third-party OpenAI-compatible API (e.g. one-api, new-api).
# Takes priority over Codex backend when both are configured.
# OPENAI_COMPAT_BASE_URL=https://example.com/v1
# OPENAI_COMPAT_API_KEY=sk-xxx
# Optional HTTP/HTTPS/SOCKS5 proxy for OpenAI-compatible requests
# OPENAI_COMPAT_PROXY_URL=socks5://127.0.0.1:1080

